{
 "pages": [
  {
   "lines": [
    "En trevlig",
    "överraskning",
    "väntar dig"
   ]
  },
  {
   "lines": [
    "Ditt hårda",
    "arbete lönar",
    "sig snart"
   ]
  },
  {
   "lines": [
    "En lång resa",
    "börjar med",
    "ett steg"
   ]
  },
  {
   "lines": [
    "Tålamod är",
    "nyckeln till",
    "glädje"
   ]
  },
  {
   "lines": [
    "Lyckan står",
    "den djärve bi",
    ""
   ]
  },
  {
   "lines": [
    "Allt gott",
    "kommer till den",
    "som väntar"
   ]
  },
  {
   "lines": [
    "Ett leende",
    "rättar till",
    "allt"
   ]
  },
  {
   "lines": [
    "Det bästa",
    "ligger ännu",
    "framför dig"
   ]
  },
  {
   "lines": [
    "Tro på dig",
    "själv och dina",
    "drömmar"
   ]
  },
  {
   "lines": [
    "En nystart",
    "sätter dig på",
    "rätt väg"
   ]
  },
  {
   "lines": [
    "Dina talanger",
    "kommer att",
    "uppmärksammas"
   ]
  },
  {
   "lines": [
    "Äventyr kan",
    "vara äkta",
    "lycka"
   ]
  },
  {
   "lines": [
    "Hemligheten",
    "bakom framgång",
    "är att börja"
   ]
  },
  {
   "lines": [
    "Din vänlighet",
    "leder dig till",
    "framgång"
   ]
  },
  {
   "lines": [
    "Varje dag är",
    "en ny chans",
    "att stråla"
   ]
  },
  {
   "lines": [
    "Lyckan kommer",
    "inifrån",
    ""
   ]
  },
  {
   "lines": [
    "Ett liv fullt",
    "av glädje",
    "väntar dig"
   ]
  },
  {
   "lines": [
    "Ditt leende",
    "ger andra",
    "ljus"
   ]
  },
  {
   "lines": [
    "Stora tankar",
    "kommer från",
    "hjärtat"
   ]
  },
  {
   "lines": [
    "Nu är det dags",
    "att prova",
    "något nytt"
   ]
  },
  {
   "lines": [
    "Du kommer att",
    "finna det du",
    "söker"
   ]
  },
  {
   "lines": [
    "Var trogen dig",
    "själv och dina",
    "värderingar"
   ]
  },
  {
   "lines": [
    "Rikedomens",
    "stjärna lyser",
    "på dig"
   ]
  },
  {
   "lines": [
    "Kärleken är på",
    "väg till dig",
    ""
   ]
  },
  {
   "lines": [
    "Din framtid är",
    "ljus och full",
    "av glädje"
   ]
  }
 ]
}

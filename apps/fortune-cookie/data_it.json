{
 "pages": [
  {
   "lines": [
    "Una piacevole",
    "sorpresa ti",
    "aspetta"
   ]
  },
  {
   "lines": [
    "Il tuo impegno",
    "darà presto i",
    "suoi frutti"
   ]
  },
  {
   "lines": [
    "Un lungo",
    "viaggio inizia",
    "con un passo"
   ]
  },
  {
   "lines": [
    "La pazienza è",
    "la chiave",
    "della gioia"
   ]
  },
  {
   "lines": [
    "La fortuna",
    "aiuta gli",
    "audaci"
   ]
  },
  {
   "lines": [
    "Le cose belle",
    "arrivano a chi",
    "sa aspettare"
   ]
  },
  {
   "lines": [
    "Un sorriso",
    "rimette tutto",
    "a posto"
   ]
  },
  {
   "lines": [
    "Il meglio deve",
    "ancora venire",
    ""
   ]
  },
  {
   "lines": [
    "Credi in te e",
    "nei tuoi sogni",
    ""
   ]
  },
  {
   "lines": [
    "Un nuovo",
    "inizio ti",
    "aprirà la via"
   ]
  },
  {
   "lines": [
    "I tuoi talenti",
    "saranno",
    "riconosciuti"
   ]
  },
  {
   "lines": [
    "L'avventura",
    "può essere",
    "vera felicità"
   ]
  },
  {
   "lines": [
    "Il segreto per",
    "andare avanti",
    "è iniziare"
   ]
  },
  {
   "lines": [
    "La tua bontà",
    "ti porterà al",
    "successo"
   ]
  },
  {
   "lines": [
    "Ogni giorno è",
    "un'occasione",
    "per brillare"
   ]
  },
  {
   "lines": [
    "La felicità",
    "nasce dentro",
    "di te"
   ]
  },
  {
   "lines": [
    "Una vita di",
    "gioia ti",
    "attende"
   ]
  },
  {
   "lines": [
    "Il tuo sorriso",
    "dona luce agli",
    "altri"
   ]
  },
  {
   "lines": [
    "Le grandi idee",
    "nascono dal",
    "cuore"
   ]
  },
  {
   "lines": [
    "È il momento",
    "di provare",
    "cose nuove"
   ]
  },
  {
   "lines": [
    "Troverai ciò",
    "che cerchi",
    ""
   ]
  },
  {
   "lines": [
    "Resta fedele a",
    "te e ai tuoi",
    "valori"
   ]
  },
  {
   "lines": [
    "La stella",
    "della fortuna",
    "brilla su di te"
   ]
  },
  {
   "lines": [
    "L'amore è già",
    "in viaggio",
    "verso di te"
   ]
  },
  {
   "lines": [
    "Il tuo futuro",
    "è luminoso e",
    "pieno di gioia"
   ]
  }
 ]
}

{
 "pages": [
  {
   "lines": [
    "En dejlig",
    "overraskelse",
    "venter dig"
   ]
  },
  {
   "lines": [
    "Dit hårde",
    "arbejde bærer",
    "snart frugt"
   ]
  },
  {
   "lines": [
    "En lang rejse",
    "begynder med",
    "et skridt"
   ]
  },
  {
   "lines": [
    "Tålmodighed er",
    "nøglen til",
    "glæde"
   ]
  },
  {
   "lines": [
    "Lykken står",
    "den kække bi",
    ""
   ]
  },
  {
   "lines": [
    "Gode ting",
    "kommer til den",
    "der venter"
   ]
  },
  {
   "lines": [
    "Et smil retter",
    "alting op",
    ""
   ]
  },
  {
   "lines": [
    "Det bedste er",
    "endnu i vente",
    ""
   ]
  },
  {
   "lines": [
    "Tro på dig",
    "selv og dine",
    "drømme"
   ]
  },
  {
   "lines": [
    "En frisk start",
    "sætter dig på",
    "vej"
   ]
  },
  {
   "lines": [
    "Dine talenter",
    "bliver snart",
    "anerkendt"
   ]
  },
  {
   "lines": [
    "Eventyr kan",
    "være ægte",
    "lykke"
   ]
  },
  {
   "lines": [
    "Hemmeligheden",
    "bag fremgang",
    "er at begynde"
   ]
  },
  {
   "lines": [
    "Din venlighed",
    "fører dig til",
    "succes"
   ]
  },
  {
   "lines": [
    "Hver dag er en",
    "ny chance for",
    "at stråle"
   ]
  },
  {
   "lines": [
    "Lykken kommer",
    "indefra",
    ""
   ]
  },
  {
   "lines": [
    "Et liv fuldt",
    "af glæde",
    "venter dig"
   ]
  },
  {
   "lines": [
    "Dit smil giver",
    "andre lys",
    ""
   ]
  },
  {
   "lines": [
    "Store tanker",
    "kommer fra",
    "hjertet"
   ]
  },
  {
   "lines": [
    "Nu er det tid",
    "til at prøve",
    "noget nyt"
   ]
  },
  {
   "lines": [
    "Du vil finde",
    "det du søger",
    ""
   ]
  },
  {
   "lines": [
    "Vær tro mod",
    "dig selv og",
    "dine værdier"
   ]
  },
  {
   "lines": [
    "Rigdommens",
    "stjerne skinner",
    "på dig"
   ]
  },
  {
   "lines": [
    "Kærligheden er",
    "på vej til dig",
    ""
   ]
  },
  {
   "lines": [
    "Din fremtid er",
    "lys og fuld af",
    "glæde"
   ]
  }
 ]

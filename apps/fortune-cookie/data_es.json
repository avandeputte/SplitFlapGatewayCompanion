{
 "pages": [
  {
   "lines": [
    "Una grata",
    "sorpresa te",
    "espera"
   ]
  },
  {
   "lines": [
    "Tu esfuerzo",
    "pronto dará",
    "sus frutos"
   ]
  },
  {
   "lines": [
    "Un largo viaje",
    "empieza con un",
    "solo paso"
   ]
  },
  {
   "lines": [
    "La paciencia",
    "es la llave de",
    "la alegría"
   ]
  },
  {
   "lines": [
    "La fortuna",
    "sonríe a los",
    "audaces"
   ]
  },
  {
   "lines": [
    "Lo bueno llega",
    "a quien sabe",
    "esperar"
   ]
  },
  {
   "lines": [
    "Una sonrisa lo",
    "endereza todo",
    ""
   ]
  },
  {
   "lines": [
    "Lo mejor está",
    "aún por llegar",
    ""
   ]
  },
  {
   "lines": [
    "Cree en ti y",
    "en tus sueños",
    ""
   ]
  },
  {
   "lines": [
    "Un nuevo",
    "comienzo te",
    "abrirá camino"
   ]
  },
  {
   "lines": [
    "Tus talentos",
    "serán",
    "reconocidos"
   ]
  },
  {
   "lines": [
    "La aventura",
    "puede ser",
    "verdadera dicha"
   ]
  },
  {
   "lines": [
    "El secreto de",
    "avanzar es",
    "empezar"
   ]
  },
  {
   "lines": [
    "Tu bondad te",
    "llevará al",
    "éxito"
   ]
  },
  {
   "lines": [
    "Cada día es una",
    "nueva ocasión",
    "para brillar"
   ]
  },
  {
   "lines": [
    "La felicidad",
    "nace dentro de",
    "ti"
   ]
  },
  {
   "lines": [
    "Una vida de",
    "alegría te",
    "espera"
   ]
  },
  {
   "lines": [
    "Tu sonrisa da",
    "luz a los",
    "demás"
   ]
  },
  {
   "lines": [
    "Las grandes",
    "ideas nacen",
    "del corazón"
   ]
  },
  {
   "lines": [
    "Es el momento",
    "de probar algo",
    "nuevo"
   ]
  },
  {
   "lines": [
    "Encontrarás lo",
    "que buscas",
    ""
   ]
  },
  {
   "lines": [
    "Sé fiel a ti y",
    "a tus valores",
    ""
   ]
  },
  {
   "lines": [
    "La estrella de",
    "la riqueza te",
    "ilumina"
   ]
  },
  {
   "lines": [
    "El amor ya",
    "viene de",
    "camino a ti"
   ]
  },
  {
   "lines": [
    "Tu futuro es",
    "brillante y",
    "lleno de dicha"
   ]
  }
 ]
}

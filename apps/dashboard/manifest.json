{
  "id": "dashboard",
  "i18n": true,
  "name": "Dashboard",
  "icon": "🏠",
  "description": "Time + weather — a drawn overview card with a seconds sweep on a Matrix panel",
  "type": "functional",
  "surfaces": [
    "flap",
    "matrix"
  ],
  "refresh_interval": 60,
  "loop_delay": 5,
  "settings": [
    {
      "key": "clock_format",
      "label": "Time format",
      "type": "toggle",
      "size": "sm",
      "default": "24h",
      "options": [
        {
          "value": "24h",
          "label": "24h"
        },
        {
          "value": "12h",
          "label": "12h"
        }
      ]
    },
    {
      "key": "temperature_unit",
      "label": "Temperature Unit",
      "type": "toggle",
      "size": "sm",
      "default": "f",
      "options": [
        {
          "value": "f",
          "label": "F"
        },
        {
          "value": "c",
          "label": "C"
        },
        {
          "value": "k",
          "label": "K"
        }
      ]
    },
    {
      "key": "timezone",
      "label": "Timezone (override global)",
      "type": "search_chips",
      "searchUrl": "/timezones",
      "resultKey": "zones",
      "maxItems": 1,
      "global_key": true
    },
    {
      "key": "loop_delay",
      "label": "Delay Between Pages (seconds)",
      "type": "number",
      "default": "5",
      "min": "2",
      "max": "30",
      "step": "1",
      "stepper": true
    }
  ],
  "category": "data",
  "min_rows": 3,
  "min_cols": 12
}

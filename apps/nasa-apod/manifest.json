{
  "id": "nasa-apod",
  "name": "NASA Picture of the Day",
  "icon": "🔭",
  "description": "NASA Astronomy Picture of the Day title",
  "type": "functional",
  "refresh_interval": 3600,
  "loop_delay": 8,
  "category": "data",
  "min_rows": 1,
  "min_cols": 12,
  "settings": [
    {
      "key": "nasa_api_key",
      "label": "NASA API key (optional — DEMO_KEY works)",
      "type": "text",
      "default": "DEMO_KEY",
      "note": "Get a free key at api.nasa.gov for higher rate limits."
    },
    {
      "key": "loop_delay",
      "label": "Delay Between Pages (seconds)",
      "type": "number",
      "default": "8",
      "min": "2",
      "max": "30",
      "step": "1",
      "stepper": true
    }
  ]
}

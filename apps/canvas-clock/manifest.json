{
  "id": "canvas-clock",
  "name": "Analog Clock",
  "icon": "🕐",
  "description": "A real analog clock drawn on a Matrix panel — a face and sweeping hands, impossible on a flap grid",
  "type": "functional",
  "surface": "canvas",
  "refresh_interval": 1,
  "loop_delay": 1,

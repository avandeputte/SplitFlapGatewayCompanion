    {"key": "hand_color", "label": "Hands", "type": "toggle", "default": "white",
     "options": [{"value": "white", "label": "White"}, {"value": "green", "label": "Green"},
                 {"value": "cyan", "label": "Cyan"}, {"value": "orange", "label": "Orange"}]}
  ]
}

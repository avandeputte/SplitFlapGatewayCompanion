{
  "id": "hacker-news",
  "name": "Hacker News",
  "icon": "📰",
  "description": "Top stories on Hacker News",
  "type": "functional",
  "refresh_interval": 300,
  "loop_delay": 7,
  "category": "news",
  "min_rows": 2,
  "min_cols": 12,
  "settings": [
    {
      "key": "count",
      "label": "How many stories",
      "type": "number",
      "default": "3",
      "min": "1",
      "max": "8",
      "step": "1",
      "stepper": true
    },
    {
      "key": "loop_delay",
      "label": "Delay Between Pages (seconds)",
      "type": "number",
      "default": "7",
      "min": "2",
      "max": "30",
      "step": "1",
      "stepper": true
    }
  ]
}

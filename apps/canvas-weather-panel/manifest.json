{
  "id": "canvas-weather-panel",
  "name": "Weather Panel",
  "icon": "🌤️",
  "description": "Current conditions as a clean panel — a sprite condition icon, big temperature, and a 3-day strip",
  "type": "functional",
  "surfaces": ["matrix"],
  "refresh_interval": 1,
  "loop_delay": 600,
  "category": "weather",
  "settings": [
    {
      "key": "location",
      "label": "Location (leave blank for global)",
      "type": "search_chips",
      "searchUrl": "/location_search",
      "resultKey": "results",
      "maxItems": 1
    },
    {
      "key": "temperature_unit",
      "label": "Temperature Unit",
      "type": "toggle",
      "size": "sm",
      "default": "f",
      "options": [
        {"value": "f", "label": "F"},
        {"value": "c", "label": "C"},
        {"value": "k", "label": "K"}
      ]
    },
    {
      "key": "timezone",
      "label": "Timezone (override global)",
      "type": "search_chips",
      "searchUrl": "/timezones",
      "resultKey": "zones",
      "maxItems": 1,
      "global_key": true
    },
    {
      "key": "show_city",
      "label": "Show place name",
      "type": "toggle",
      "default": "yes",
      "options": [
        {"value": "yes", "label": "On"},
        {"value": "no", "label": "Off"}
      ]
    }
  ]
}

        "Concentra't i",
        "torna a provar"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "No hi comptis",
        ""
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "La meva",
        "resposta és no"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Les meves fonts",
        "diuen que no"
      ]
    },
    {
      "lines": [

        "Bola 8 Màgica",
        "És segur",
        ""
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Decididament",
        "sí"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Sense cap dubte",
        ""
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Sí,",
        "definitivament"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Pots comptar-hi",
        ""
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Tal com ho veig",
        "sí"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Molt probable",
        ""
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Té bona pinta",
        ""
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Sí",
        ""
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Els senyals",
        "diuen que sí"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Resposta vaga,",
        "prova-ho de nou"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Pregunta-ho",
        "més tard"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Millor no",
        "dir-t'ho ara"
      ]
    },
    {
      "lines": [
        "Bola 8 Màgica",
        "Ara no ho puc",
        "predir"
      ]
    },
    {
      "lines": [

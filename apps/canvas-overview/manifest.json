{
  "id": "canvas-overview",
  "name": "Overview",
  "icon": "📊",
  "description": "A clock, date and weather dashboard (Matrix panel)",
  "type": "functional",
  "surface": "canvas",
  "refresh_interval": 1,
  "loop_delay": 1,
  "category": "time",
  "settings": [
    {
      "key": "clock_format",
      "label": "Time format",
      "type": "toggle",
      "size": "sm",
      "default": "24h",
      "options": [
        {
          "value": "24h",
          "label": "24h"
        },
        {
          "value": "12h",
          "label": "12h"
        }
      ]
    },
    {
      "key": "temperature_unit",
      "label": "Temperature Unit",
      "type": "toggle",
      "size": "sm",
      "default": "f",
      "options": [
        {
          "value": "f",
          "label": "F"
        },
        {
          "value": "c",
          "label": "C"
        },
        {
          "value": "k",
          "label": "K"
        }
      ]
    },
    {
      "key": "timezone",
      "label": "Timezone (override global)",
      "type": "search_chips",
      "searchUrl": "/timezones",
      "resultKey": "zones",
      "maxItems": 1,
      "global_key": true
    }
  ]
}

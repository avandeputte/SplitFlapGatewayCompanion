{
  "id": "holidays",
  "i18n": true,
  "name": "Public Holidays",
  "icon": "📅",
  "description": "Upcoming holidays for your location — ten years bundled, works offline; optional religious observances by tradition",
  "type": "functional",
  "refresh_interval": 21600,
  "loop_delay": 6,
  "category": "data",
  "min_rows": 2,
  "min_cols": 12,
  "settings": [
    {
      "key": "country",
      "label": "Country (2-letter code)",
      "type": "text",
      "default": "",
      "size": "sm",
      "ph": "blank = follow Location",
      "note": "ISO country code, e.g. US, GB, DE, FR, CA. Blank follows your Location (then Language)."
    },
    {
      "key": "loop_delay",
      "label": "Delay Between Pages (seconds)",
      "type": "number",
      "default": "6",
      "min": "2",
      "max": "30",
      "step": "1",
      "stepper": true
    },
    {
      "key": "religious_holidays",
      "label": "Also show religious observances",
      "type": "toggle",
      "default": "off",
      "options": [
        {
          "value": "off",
          "label": "No"
        },
        {
          "value": "on",
          "label": "Yes"
        }
      ]
    },
    {
      "key": "tradition_christian",
      "label": "Christian",
      "type": "toggle",
      "default": "on",
      "options": [
        {
          "value": "on",
          "label": "Show"
        },
        {
          "value": "off",
          "label": "Hide"
        }
      ],
      "visible_when": {
        "religious_holidays": "on"
      }
    },
    {
      "key": "tradition_islamic",
      "label": "Islamic",
      "type": "toggle",
      "default": "on",

{
 "pages": [
  {
   "lines": [
    "L'obstacle és",
    "el camí",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "Patim més en",
    "la imaginació",
    "- Sèneca"
   ]
  },
  {
   "lines": [
    "No perdis temps",
    "en discussions",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "Tens poder",
    "sobre la ment",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "Comença ara",
    "a viure",
    "- Sèneca"
   ]
  },
  {
   "lines": [
    "Mira la bellesa",
    "de la vida",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "Res de gran no",
    "ve de sobte",
    "- Epictet"
   ]
  },
  {
   "lines": [
    "L'ús endureix",
    "la ment",
    "- Sèneca"
   ]
  },
  {
   "lines": [
    "Suporta i",
    "renuncia",
    "- Epictet"
   ]
  },
  {
   "lines": [
    "Sigues tolerant",
    "amb els altres",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "Estima la sort",
    "que et toca",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "És llarga la",
    "vida si en saps",
    "- Sèneca"
   ]
  },
  {
   "lines": [
    "Tingues cura",
    "d'aquest moment",
    "- Epictet"
   ]
  },
  {
   "lines": [
    "La felicitat",
    "vera és virtut",
    "- Sèneca"
   ]
  },
  {
   "lines": [
    "Domina't abans",
    "que els altres",
    "- Epictet"
   ]
  },
  {
   "lines": [
    "Tria no ser",
    "ferit",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "El que fem ara",
    "ressona sempre",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "Mentre esperem",
    "la vida passa",
    "- Sèneca"
   ]
  },
  {
   "lines": [
    "Pensa en allò",
    "que tens",
    "- Marc Aureli"
   ]
  },
  {
   "lines": [
    "Cada nou dia",
    "és una ocasió",
    "- Sèneca"
   ]
  }
 ]
}

{
 "pages": [
  {
   "lines": [
    "El obstáculo",
    "es el camino",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Sufrimos más en",
    "la imaginación",
    "- Séneca"
   ]
  },
  {
   "lines": [
    "No pierdas el",
    "tiempo en riñas",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Tienes poder",
    "sobre tu mente",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Empieza ya",
    "a vivir",
    "- Séneca"
   ]
  },
  {
   "lines": [
    "Mira la belleza",
    "de la vida",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Nada grande",
    "surge de pronto",
    "- Epicteto"
   ]
  },
  {
   "lines": [
    "El uso endurece",
    "la mente",
    "- Séneca"
   ]
  },
  {
   "lines": [
    "Soporta y",
    "renuncia",
    "- Epicteto"
   ]
  },
  {
   "lines": [
    "Sé tolerante",
    "con los demás",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Ama la suerte",
    "que te tocó",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "La vida, bien",
    "usada, es larga",
    "- Séneca"
   ]
  },
  {
   "lines": [
    "Cuida este",
    "momento",
    "- Epicteto"
   ]
  },
  {
   "lines": [
    "La verdadera",
    "dicha es virtud",
    "- Séneca"
   ]
  },
  {
   "lines": [
    "Domínate, luego",
    "a los demás",
    "- Epicteto"
   ]
  },
  {
   "lines": [
    "Elige no ser",
    "dañado",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Lo que hacemos",
    "resuena siempre",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Esperando se",
    "va la vida",
    "- Séneca"
   ]
  },
  {
   "lines": [
    "Piensa en lo",
    "que tienes",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Cada nuevo día",
    "es una ocasión",
    "- Séneca"
   ]
  }
 ]

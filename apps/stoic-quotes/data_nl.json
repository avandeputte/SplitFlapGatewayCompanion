{
 "pages": [
  {
   "lines": [
    "Het obstakel",
    "is de weg",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "We lijden meer",
    "in de fantasie",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Verspil geen",
    "tijd aan ruzie",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Je hebt macht",
    "over je geest",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Begin meteen",
    "te leven",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Zie het mooie",
    "van het leven",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Niets groots",
    "komt plotseling",
    "- Epictetus"
   ]
  },
  {
   "lines": [
    "Train de geest",
    "door gebruik",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Verdraag en",
    "verzaak",
    "- Epictetus"
   ]
  },
  {
   "lines": [
    "Wees mild voor",
    "anderen",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Heb je lot lief",
    "",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Leven is lang",
    "als je 't benut",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Koester dit",
    "moment",
    "- Epictetus"
   ]
  },
  {
   "lines": [
    "Echt geluk",
    "is een deugd",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Beheers jezelf",
    "dan anderen",
    "- Epictetus"
   ]
  },
  {
   "lines": [
    "Kies: word niet",
    "gekwetst",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Wat we nu doen",
    "echoot eeuwig",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Wie wacht, ziet",
    "het leven gaan",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Denk aan wat",
    "je hebt",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Elke nieuwe dag",
    "is een kans",
    "- Seneca"
   ]
  }
 ]
}

{
 "pages": [
  {
   "lines": [
    "L'ostacolo",
    "è la via",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Soffriamo più",
    "immaginando",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Non perdere",
    "tempo in liti",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Hai potere",
    "sulla tua mente",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Comincia ora",
    "a vivere",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Contempla il",
    "bello di vivere",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Nulla di grande",
    "nasce di colpo",
    "- Epitteto"
   ]
  },
  {
   "lines": [
    "L'uso tempra",
    "la mente",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Sopporta e",
    "astieniti",
    "- Epitteto"
   ]
  },
  {
   "lines": [
    "Sii tollerante",
    "con gli altri",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Ama la sorte",
    "che ti tocca",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "La vita è lunga",
    "se sai usarla",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Abbi cura di",
    "questo istante",
    "- Epitteto"
   ]
  },
  {
   "lines": [
    "Vera felicità",
    "è la virtù",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Vinci te stesso",
    "poi gli altri",
    "- Epitteto"
   ]
  },
  {
   "lines": [
    "Scegli di non",
    "essere leso",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Ciò che fai ora",
    "risuona sempre",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Mentre attendi",
    "la vita passa",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Pensa a ciò",
    "che hai",
    "- Marco Aurelio"
   ]
  },
  {
   "lines": [
    "Un nuovo giorno",
    "è un'occasione",
    "- Seneca"
   ]
  }
 ]
}

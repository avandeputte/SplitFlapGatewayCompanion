{
 "pages": [
  {
   "lines": [
    "Hindringen",
    "er vejen",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Vi lider mere i",
    "fantasien",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Spild ikke tid",
    "på skænderier",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Du har magt",
    "over dit sind",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Begynd straks",
    "at leve",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Dvæl ved livets",
    "skønhed",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Intet stort",
    "sker pludseligt",
    "- Epiktet"
   ]
  },
  {
   "lines": [
    "Hærd sindet",
    "gennem brug",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Udhold og",
    "forsag",
    "- Epiktet"
   ]
  },
  {
   "lines": [
    "Vær tolerant",
    "mod andre",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Elsk den skæbne",
    "du får",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Livet er langt,",
    "bruger du det",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Værn om dette",
    "øjeblik",
    "- Epiktet"
   ]
  },
  {
   "lines": [
    "Sand lykke",
    "er en dyd",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Behersk dig",
    "selv før andre",
    "- Epiktet"
   ]
  },
  {
   "lines": [
    "Vælg ikke at",
    "blive krænket",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Hvad vi gør nu",
    "runger evigt",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Mens vi venter",
    "går livet forbi",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Tænk på hvad",
    "du har",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Hver ny dag",
    "er en chance",
    "- Seneca"
   ]
  }
 ]
}

   "lines": [
    "O obstáculo",
    "é o caminho",
    "- Marco Aurélio"
   ]
  },
  {
   "lines": [
    "Sofremos mais",
    "na imaginação",
    "- Séneca"
   ]
  },
  {
   "lines": [
    "Não percas",
    "tempo em rixas",
    "- Marco Aurélio"
   ]
  },
  {
   "lines": [
    "Tens poder",
    "sobre a mente",
    "- Marco Aurélio"
   ]
  },
  {
   "lines": [
    "Começa já",
    "a viver",
    "- Séneca"
   ]
  },
  {
   "lines": [
    "Contempla a",
    "beleza da vida",
    "- Marco Aurélio"
   ]
  },
  {
   "lines": [
    "Nada de grande",
    "surge de súbito",
    "- Epicteto"
   ]
  },
  {
   "lines": [
    "O uso endurece",
    "a mente",

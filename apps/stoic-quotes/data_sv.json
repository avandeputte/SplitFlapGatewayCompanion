{
 "pages": [
  {
   "lines": [
    "Hindret är",
    "vägen",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Vi lider mer i",
    "inbillningen",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Slösa ingen tid",
    "på gräl",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Du har makt",
    "över ditt sinne",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Börja genast",
    "att leva",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Dröj vid livets",
    "skönhet",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Inget stort",
    "sker plötsligt",
    "- Epiktetos"
   ]
  },
  {
   "lines": [
    "Härda sinnet",
    "genom bruk",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Tål och försaka",
    "",
    "- Epiktetos"
   ]
  },
  {
   "lines": [
    "Var tolerant",
    "mot andra",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Älska det öde",
    "du får",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Livet är långt",
    "om du vet hur",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Vårda detta",
    "ögonblick",
    "- Epiktetos"
   ]
  },
  {
   "lines": [
    "Sann lycka",
    "är en dygd",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Styr dig själv,",
    "sedan andra",
    "- Epiktetos"
   ]
  },
  {
   "lines": [
    "Välj att inte",
    "bli sårad",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Det vi gör nu",
    "ekar för evigt",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Medan vi väntar",
    "går livet förbi",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Tänk på det",
    "du har",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Varje ny dag",
    "är en chans",
    "- Seneca"
   ]
  }
 ]
}

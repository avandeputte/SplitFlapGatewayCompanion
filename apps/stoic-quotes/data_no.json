{
 "pages": [
  {
   "lines": [
    "Hindringen",
    "er veien",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Vi lider mer i",
    "fantasien",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Kast ikke bort",
    "tid på krangel",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Du har makt",
    "over ditt sinn",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Begynn straks",
    "å leve",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Dvel ved livets",
    "skjønnhet",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Intet stort",
    "kommer brått",
    "- Epiktet"
   ]
  },
  {
   "lines": [
    "Herd sinnet",
    "gjennom bruk",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Tål og forsak",
    "",
    "- Epiktet"
   ]
  },
  {
   "lines": [
    "Vær tolerant",
    "mot andre",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Elsk skjebnen",
    "du får",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Livet er langt,",
    "bruker du det",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Vern om dette",
    "øyeblikket",
    "- Epiktet"
   ]
  },
  {
   "lines": [
    "Ekte lykke",
    "er en dyd",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Mestre deg selv",
    "før andre",
    "- Epiktet"
   ]
  },
  {
   "lines": [
    "Velg å ikke",
    "bli krenket",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Det vi gjør nå",
    "runger evig",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Mens vi venter",
    "går livet forbi",
    "- Seneca"
   ]
  },
  {
   "lines": [
    "Tenk på det",
    "du har",
    "- Marcus"
   ]
  },
  {
   "lines": [
    "Hver ny dag",
    "er en sjanse",
    "- Seneca"
   ]
  }
 ]
}

{
  "id": "art-clock",
  "name": "Art Clock",
  "icon": "🎨",
  "description": "Time as color art",
  "category": "time",
  "type": "functional",
  "surfaces": ["flap"],
  "version": "1.0",
  "refresh_interval": 60,
  "loop_delay": 1,
  "animation": true,
  "settings": [
    {
      "key": "clock_format",
      "label": "Clock Format",
      "type": "toggle",
      "default": "auto",
      "options": [
        {"value": "auto", "label": "Auto (AM/PM in English)"},
        {"value": "12h",  "label": "12-hour (AM/PM)"},
        {"value": "24h",  "label": "24-hour"}
      ]
    },
    {
      "key": "timezone",
      "label": "Timezone (override global)",
      "type": "search_chips",
      "searchUrl": "/timezones",
      "resultKey": "zones",
      "maxItems": 1,
      "global_key": true
    }
  ],
  "min_rows": 3,
  "min_cols": 15
}

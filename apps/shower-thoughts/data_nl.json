{
 "pages": [
  {
   "lines": [
    "Niets staat in",
    "brand. Brand",
    "staat op dingen"
   ]
  },
  {
   "lines": [
    "Het woord bed",
    "ziet eruit als",
    "een bed"
   ]
  },
  {
   "lines": [
    "Je toekomstige",
    "ik zit naar je",
    "te kijken"
   ]
  },
  {
   "lines": [
    "Elk boek is",
    "een remix van",
    "het alfabet"
   ]
  },
  {
   "lines": [
    "Je hebt je",
    "gezicht nooit",
    "echt gezien"
   ]
  },
  {
   "lines": [
    "Lasagne is",
    "gewoon een",
    "pastataart"
   ]
  },
  {
   "lines": [
    "De zee is",
    "gewoon water",
    "met een smaakje"
   ]
  },
  {
   "lines": [
    "Elke uitgang",
    "is elders een",
    "ingang"
   ]
  },
  {
   "lines": [
    "Je bent nu",
    "ouder dan ooit",
    ""
   ]
  },
  {
   "lines": [
    "Tanden: de",
    "enige botten",
    "die je poetst"
   ]
  },
  {
   "lines": [
    "Zwanen kunnen",
    "gay zijn en dat",
    "is prachtig"
   ]
  },
  {
   "lines": [
    "Geschiedenis",
    "wordt elk jaar",
    "langer"
   ]
  },
  {
   "lines": [
    "Je hond weet",
    "niet of je rent",
    "of struikelt"
   ]
  },
  {
   "lines": [
    "Koffie is",
    "gewoon heet",
    "bonenwater"
   ]
  },
  {
   "lines": [
    "Een lift is",
    "gewoon een",
    "kamer die rijdt"
   ]
  },
  {
   "lines": [
    "Wachtend op de",
    "ober dien je",
    "nergens toe"
   ]
  },
  {
   "lines": [
    "Elke spiegel",
    "die je koopt is",
    "tweedehands"
   ]
  },
  {
   "lines": [
    "Zand heet zand",
    "want zee",
    "en land"
   ]
  },
  {
   "lines": [
    "Verjaardagen",
    "zijn gezond.",
    "Hoe meer, hoe"
   ]
  },
  {
   "lines": [
    "beter. Met de",
    "meeste leef je",
    "het langst"
   ]
  },
  {
   "lines": [
    "Slapen is",
    "gewoon",
    "tijdreizen"
   ]
  },
  {
   "lines": [
    "Een kaart is",
    "een spoiler",
    "van je reis"
   ]
  },
  {
   "lines": [
    "Regen is",
    "confetti uit",
    "de lucht"
   ]
  },
  {
   "lines": [
    "Sokken zijn",
    "schoenen voor",
    "je schoenen"
   ]
  },
  {
   "lines": [
    "Klappen is",
    "jezelf slaan",
    ""
   ]
  }
 ]
}

{
 "pages": [
  {
   "lines": [
    "Intet står i",
    "flammer. De",
    "står på tingene"
   ]
  },
  {
   "lines": [
    "Det engelske",
    "ord bed ligner",
    "en seng"
   ]
  },
  {
   "lines": [
    "Dit fremtidige",
    "jeg holder øje",
    "med dig"
   ]
  },
  {
   "lines": [
    "Enhver bog er",
    "et remix af",
    "alfabetet"
   ]
  },
  {
   "lines": [
    "Du har aldrig",
    "set dit eget",
    "ansigt live"
   ]
  },
  {
   "lines": [
    "Lasagne er",
    "bare en",
    "pastakage"
   ]
  },
  {
   "lines": [
    "Havet er bare",
    "vand med smag",
    ""
   ]
  },
  {
   "lines": [
    "Enhver udgang",
    "er en indgang",
    "et andet sted"
   ]
  },
  {
   "lines": [
    "Du har aldrig",
    "været så",
    "gammel som nu"
   ]
  },
  {
   "lines": [
    "Tænder: de",
    "eneste knogler",
    "du børster"
   ]
  },
  {
   "lines": [
    "Svaner kan være",
    "homoseksuelle",
    "og det er smukt"
   ]
  },
  {
   "lines": [
    "Historietimen",
    "bliver længere",
    "hvert år"
   ]
  },
  {
   "lines": [
    "Din hund ved",
    "ikke om du løb",
    "eller snublede"
   ]
  },
  {
   "lines": [
    "Kaffe er bare",
    "varmt",
    "bønnevand"
   ]
  },
  {
   "lines": [
    "En elevator er",
    "bare et rum,",
    "der kører"
   ]
  },
  {
   "lines": [
    "Mens du venter",
    "på tjeneren,",
    "tjener du intet"
   ]
  },
  {
   "lines": [
    "Alle spejle du",
    "køber er",
    "brugte"
   ]
  },
  {
   "lines": [
    "Sand hedder",
    "sand fordi",
    "sø og land"
   ]
  },
  {
   "lines": [
    "Fødselsdage er",
    "sunde: jo",
    "flere, jo bedre"
   ]
  },
  {
   "lines": [
    "Folk med flest",
    "lever længst",
    ""
   ]
  },
  {
   "lines": [
    "At sove er",
    "bare en",
    "tidsrejse"
   ]
  },
  {
   "lines": [
    "Et kort er en",
    "spoiler for",
    "rejsen"
   ]
  },
  {
   "lines": [
    "Regn er bare",
    "konfetti fra",
    "himlen"
   ]
  },
  {
   "lines": [
    "Sokker er sko",
    "til dine sko",
    ""
   ]
  },
  {
   "lines": [
    "At klappe er",
    "at slå sig",
    "selv"
   ]
  }
 ]
}

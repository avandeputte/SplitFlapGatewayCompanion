{
 "pages": [
  {
   "lines": [
    "Res no s'encén.",
    "El foc encén",
    "les coses"
   ]
  },
  {
   "lines": [
    "La paraula bed",
    "té forma de",
    "llit"
   ]
  },
  {
   "lines": [
    "El teu jo del",
    "futur t'està",
    "mirant"
   ]
  },
  {
   "lines": [
    "Cada llibre és",
    "un remix de",
    "l'abecedari"
   ]
  },
  {
   "lines": [
    "Mai has vist",
    "la teva cara",
    "en persona"
   ]
  },
  {
   "lines": [
    "La lasanya és",
    "només un pastís",
    "de pasta"
   ]
  },
  {
   "lines": [
    "El mar és",
    "només aigua",
    "amb gust"
   ]
  },
  {
   "lines": [
    "Cada sortida",
    "és una entrada",
    "a un altre lloc"
   ]
  },
  {
   "lines": [
    "Mai no havies",
    "estat tan vell",
    "com ara"
   ]
  },
  {
   "lines": [
    "Les dents: els",
    "únics ossos",
    "que rentes"
   ]
  },
  {
   "lines": [
    "Els cignes",
    "poden ser gais",
    "i és preciós"
   ]
  },
  {
   "lines": [
    "La classe",
    "d'història",
    "creix cada any"
   ]
  },
  {
   "lines": [
    "El teu gos no",
    "sap si corres",
    "o caus"
   ]
  },
  {
   "lines": [
    "El cafè és",
    "aigua calenta",
    "de grans"
   ]
  },
  {
   "lines": [
    "L'ascensor és",
    "una habitació",
    "que es mou"
   ]
  },
  {
   "lines": [
    "Si esperes el",
    "cambrer, tu no",
    "serveixes"
   ]
  },
  {
   "lines": [
    "Tot mirall que",
    "compres és de",
    "segona mà"
   ]
  },
  {
   "lines": [
    "La sorra és una",
    "muntanya",
    "jubilada"
   ]
  },
  {
   "lines": [
    "Els aniversaris",
    "són sans: com",
    "més, millor."
   ]
  },
  {
   "lines": [
    "Qui més en té,",
    "més anys viu",
    ""
   ]
  },
  {
   "lines": [
    "Dormir és",
    "només viatjar",
    "en el temps"
   ]
  },
  {
   "lines": [
    "Un mapa és",
    "un espòiler",
    "del viatge"
   ]
  },
  {
   "lines": [
    "La pluja és",
    "confeti del",
    "cel"
   ]
  },
  {
   "lines": [
    "Els mitjons",
    "són sabates",
    "de les sabates"
   ]
  },
  {
   "lines": [
    "Aplaudir és",
    "pegar-te a tu",
    "mateix"
   ]
  }
 ]
}

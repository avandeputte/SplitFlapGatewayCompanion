{
 "pages": [
  {
   "lines": [
    "Nada prende",
    "fuego. El fuego",
    "prende cosas"
   ]
  },
  {
   "lines": [
    "La palabra bed",
    "tiene forma de",
    "cama"
   ]
  },
  {
   "lines": [
    "Tu yo del",
    "futuro te está",
    "mirando"
   ]
  },
  {
   "lines": [
    "Todo libro es",
    "un remix del",
    "abecedario"
   ]
  },
  {
   "lines": [
    "Nunca has visto",
    "tu propia cara",
    "en persona"
   ]
  },
  {
   "lines": [
    "La lasaña es",
    "solo una tarta",
    "de pasta"
   ]
  },
  {
   "lines": [
    "El mar es solo",
    "agua con sabor",
    ""
   ]
  },
  {
   "lines": [
    "Cada salida es",
    "una entrada en",
    "otro lugar"
   ]
  },
  {
   "lines": [
    "Nunca habías",
    "sido tan viejo",
    "como ahora"
   ]
  },
  {
   "lines": [
    "Dientes: los",
    "únicos huesos",
    "que limpias"
   ]
  },
  {
   "lines": [
    "Los cisnes",
    "pueden ser gais",
    "y es precioso"
   ]
  },
  {
   "lines": [
    "La clase de",
    "historia crece",
    "cada año"
   ]
  },
  {
   "lines": [
    "Tu perro no",
    "sabe si corres",
    "o te caes"
   ]
  },
  {
   "lines": [
    "El café es solo",
    "agua caliente",
    "de granos"
   ]
  },
  {
   "lines": [
    "El ascensor es",
    "un cuarto que",
    "se mueve"
   ]
  },
  {
   "lines": [
    "Esperando al",
    "camarero no",
    "sirves de nada"
   ]
  },
  {
   "lines": [
    "Todo espejo",
    "que compras es",
    "de segunda mano"
   ]
  },
  {
   "lines": [
    "La arena es",
    "una montaña",
    "jubilada"
   ]
  },
  {
   "lines": [
    "Los cumpleaños",
    "son sanos:",
    "cuantos más,"
   ]
  },
  {
   "lines": [
    "mejor. Quien",
    "más tiene, más",
    "vive"
   ]
  },
  {
   "lines": [
    "Dormir es solo",
    "viajar en el",
    "tiempo"
   ]
  },
  {
   "lines": [
    "Un mapa es el",
    "spoiler del",
    "viaje"
   ]
  },
  {
   "lines": [
    "La lluvia es",
    "confeti del",
    "cielo"
   ]
  },
  {
   "lines": [
    "Los calcetines",
    "son zapatos",
    "de tus zapatos"
   ]
  },
  {
   "lines": [
    "Aplaudir es",
    "pegarte a ti",
    "mismo"
   ]
  }
 ]
}

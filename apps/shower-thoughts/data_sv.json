{
 "pages": [
  {
   "lines": [
    "Inget står i",
    "lågor. Lågorna",
    "står på saker"
   ]
  },
  {
   "lines": [
    "Engelska ordet",
    "bed ser ut som",
    "en säng"
   ]
  },
  {
   "lines": [
    "Ditt framtida",
    "jag tittar på",
    "dig just nu"
   ]
  },
  {
   "lines": [
    "Varje bok är",
    "en remix av",
    "alfabetet"
   ]
  },
  {
   "lines": [
    "Du har aldrig",
    "sett ditt eget",
    "ansikte live"
   ]
  },
  {
   "lines": [
    "Lasagne är",
    "bara en",
    "pastatårta"
   ]
  },
  {
   "lines": [
    "Havet är bara",
    "smaksatt",
    "vatten"
   ]
  },
  {
   "lines": [
    "Varje utgång",
    "är en ingång",
    "nån annanstans"
   ]
  },
  {
   "lines": [
    "Du har aldrig",
    "varit så",
    "gammal som nu"
   ]
  },
  {
   "lines": [
    "Tänder: de enda",
    "ben du borstar",
    "varje dag"
   ]
  },
  {
   "lines": [
    "Svanar kan",
    "vara gay och",
    "det är vackert"
   ]
  },
  {
   "lines": [
    "Historieämnet",
    "blir längre",
    "varje år"
   ]
  },
  {
   "lines": [
    "Din hund vet ej",
    "om du sprang",
    "eller snubblade"
   ]
  },
  {
   "lines": [
    "Kaffe är bara",
    "varmt",
    "bönvatten"
   ]
  },
  {
   "lines": [
    "En hiss är bara",
    "ett rum som",
    "åker"
   ]
  },
  {
   "lines": [
    "Servitören",
    "serverar dig",
    "väntan"
   ]
  },
  {
   "lines": [
    "Alla speglar",
    "du köper är",
    "begagnade"
   ]
  },
  {
   "lines": [
    "Sand heter sand",
    "tack vare sjö",
    "och land"
   ]
  },
  {
   "lines": [
    "Födelsedagar",
    "är nyttiga: ju",
    "fler, desto"
   ]
  },
  {
   "lines": [
    "bättre. Folk",
    "med flest lever",
    "längst"
   ]
  },
  {
   "lines": [
    "Att sova är",
    "bara en",
    "tidsresa"
   ]
  },
  {
   "lines": [
    "En karta är en",
    "spoiler för",
    "resan"
   ]
  },
  {
   "lines": [
    "Regn är bara",
    "konfetti från",
    "himlen"
   ]
  },
  {
   "lines": [
    "Strumpor är",
    "skor för dina",
    "skor"
   ]
  },
  {
   "lines": [
    "Applåder är",
    "bara att slå",
    "sig själv"
   ]
  }
 ]
}

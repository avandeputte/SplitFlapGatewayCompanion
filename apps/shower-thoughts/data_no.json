{
 "pages": [
  {
   "lines": [
    "Ingenting er i",
    "brann. Brannen",
    "er på tingene"
   ]
  },
  {
   "lines": [
    "Det engelske",
    "ordet bed",
    "ligner en seng"
   ]
  },
  {
   "lines": [
    "Ditt fremtidige",
    "jeg ser på deg",
    "akkurat nå"
   ]
  },
  {
   "lines": [
    "Hver bok er",
    "en remix av",
    "alfabetet"
   ]
  },
  {
   "lines": [
    "Du har aldri",
    "sett ditt eget",
    "ansikt live"
   ]
  },
  {
   "lines": [
    "Lasagne er",
    "bare en",
    "pastakake"
   ]
  },
  {
   "lines": [
    "Havet er bare",
    "vann med smak",
    ""
   ]
  },
  {
   "lines": [
    "Hver utgang er",
    "en inngang et",
    "annet sted"
   ]
  },
  {
   "lines": [
    "Du har aldri",
    "vært så gammel",
    "som nå"
   ]
  },
  {
   "lines": [
    "Tenner: de",
    "eneste knoklene",
    "du pusser"
   ]
  },
  {
   "lines": [
    "Svaner kan være",
    "homofile og det",
    "er vakkert"
   ]
  },
  {
   "lines": [
    "Historietimen",
    "blir lengre",
    "hvert år"
   ]
  },
  {
   "lines": [
    "Hunden din vet",
    "ikke om du løp",
    "eller snublet"
   ]
  },
  {
   "lines": [
    "Kaffe er bare",
    "varmt",
    "bønnevann"
   ]
  },
  {
   "lines": [
    "En heis er bare",
    "et rom som",
    "kjører"
   ]
  },
  {
   "lines": [
    "Servitøren",
    "serverer deg",
    "ventetid"
   ]
  },
  {
   "lines": [
    "Alle speil du",
    "kjøper er",
    "brukte"
   ]
  },
  {
   "lines": [
    "Sand heter sand",
    "fordi sjø",
    "og land"
   ]
  },
  {
   "lines": [
    "Bursdager er",
    "sunne: jo",
    "flere, jo bedre"
   ]
  },
  {
   "lines": [
    "Folk med flest",
    "lever lengst",
    ""
   ]
  },
  {
   "lines": [
    "Å sove er bare",
    "en tidsreise",
    ""
   ]
  },
  {
   "lines": [
    "Et kart er en",
    "spoiler for",
    "turen"
   ]
  },
  {
   "lines": [
    "Regn er bare",
    "konfetti fra",
    "himmelen"
   ]
  },
  {
   "lines": [
    "Sokker er sko",
    "til skoene",
    "dine"
   ]
  },
  {
   "lines": [
    "Å klappe er å",
    "slå seg selv",
    ""
   ]
  }
 ]
}

# SplitFlap Gateway Companion — environment configuration.
# Copy to .env and adjust. Env vars always win over the saved config.json.
# The gateway is the source of truth for grid size + MQTT, so normally you only
# need COMPANION_GATEWAY_URL (and a password if your broker needs auth).

# Gateway base URL (config sync + REST transport + status + Display link)
COMPANION_GATEWAY_URL=http://splitflap-gateway.local

# This companion's own URL, registered with the gateway (v3.0+) so the gateway
# shows a "Companion" tab linking back here. Blank = don't register.
COMPANION_PUBLIC_URL=http://companion-host:8000

# Display transport: sim | mqtt | rest
COMPANION_TRANSPORT=sim

# MQTT password (the gateway never exposes this) — blank for an anonymous broker
# COMPANION_MQTT_PASSWORD=

# Module id of grid index 0 (companion-owned; not read from the gateway)
COMPANION_MODULE_ID_BASE=0

# Pull grid + MQTT from the gateway on startup (default true)
# COMPANION_SYNC_FROM_GATEWAY=true

# --- Manual overrides (only if NOT reading these from the gateway) ---
# COMPANION_GRID_ROWS=3
# COMPANION_GRID_COLS=15
# COMPANION_MQTT_BROKER=192.168.1.50
# COMPANION_MQTT_PORT=1883
# COMPANION_MQTT_PREFIX=splitflap
# COMPANION_MQTT_USER=

# Where config + state live (a volume in Docker)
# COMPANION_DATA_DIR=/data

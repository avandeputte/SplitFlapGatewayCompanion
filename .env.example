# SplitFlap Gateway Companion — environment configuration.
# Copy to .env and adjust. The companion has no config file — these env vars,
# the gateway's /api/config, and built-in defaults are the whole configuration.
# The gateway is the source of truth for grid size + MQTT, so normally GATEWAY_URL
# is the only thing you set (plus a password if your broker needs auth).

# Gateway base URL (REQUIRED — the companion refuses to start without it; there
# is no default). Used for the REST transport, config sync, status + Display link.
GATEWAY_URL=http://192.168.1.50

# --- Container image (docker-compose) -------------------------------------
# Your GitHub user/org, so compose can pull the published image
# ghcr.io/<GHCR_OWNER>/splitflap-gateway-companion. Only needed to PULL a
# prebuilt image; `docker compose build` works without it.
# GHCR_OWNER=avandeputte
# COMPANION_TAG=latest        # pin a specific release, e.g. 0.1.0

# This companion's own URL, registered with the gateway (v3.0+) so the gateway
# shows a "Companion" tab linking back here. Blank = don't register.
COMPANION_PUBLIC_URL=http://companion-host:8000

# The companion ALWAYS drives the gateway over REST (/api/rs485/batch, Gateway
# 3.0+). There is no transport setting. MQTT is used only for Home Assistant.

# MQTT password (the gateway never exposes this) — blank for an anonymous broker
# COMPANION_MQTT_PASSWORD=

# Home Assistant integration: auto (follow the gateway's HA setting) | true | false
# Uses the same MQTT broker as the gateway. Publishes a "SplitFlap Companion"
# device with the companion-unique controls: App/Playlist selects + a Stop button.
COMPANION_HA=auto

# Module id of grid index 0 (companion-owned; not read from the gateway)
COMPANION_MODULE_ID_BASE=0

# --- Vestaboard-compatible API (off by default) ---------------------------
# Makes this display answer the Vestaboard Local API, so anything that already
# speaks to a Vestaboard — a Home Assistant rest_command, the HACS integration, a
# script — can drive it: POST /local-api/message with a character-code matrix (or
# {"text": "..."}, an extension of ours). A Vestaboard Note is 3x15, i.e. exactly
# the default grid; a 6x22 Flagship message is compacted onto whatever wall you have.
# A message takes the display over, like a Compose push. Clients that hard-code a
# board's port 7000 are satisfied by publishing the container as -p 7000:8000.
# It can also be toggled at runtime from the UI's ⚙ tools menu.
# COMPANION_VESTABOARD=1

# The Local API key clients must send as X-Vestaboard-Local-Api-Key. Leave blank and
# one is generated on first use and kept with your settings (read it from the Dev
# menu). NOTE: it guards ONLY the /local-api/* routes — the rest of the companion's
# API is unauthenticated, as it always was.
# COMPANION_VESTABOARD_KEY=

# Optional: enables Vestaboard's enablement handshake — POST /local-api/enablement
# with this as X-Vestaboard-Local-Api-Enablement-Token returns the API key above.
# Unset (the default) simply refuses that exchange; take the key from the ⚙ menu.
# COMPANION_VESTABOARD_ENABLEMENT_TOKEN=

# --- MCP server (off by default) ------------------------------------------
# Exposes the display as MCP tools at /mcp, so an LLM client (Claude, an agent) can
# show a message, run an app, or read what's on the flaps. Like the Vestaboard layer:
# off unless asked for, 404 as a whole when off, and toggleable from the ⚙ menu.
# COMPANION_MCP=1

# The bearer token clients send as "Authorization: Bearer ...". Leave blank and one is
# generated on first use and kept with your settings (read it from the ⚙ menu).
# NOTE: it guards ONLY /mcp — the rest of the companion's API is unauthenticated.
# COMPANION_MCP_TOKEN=


# Pull grid + MQTT from the gateway on startup (default true)
# COMPANION_SYNC_FROM_GATEWAY=true

# --- Manual overrides (only if NOT reading these from the gateway) ---
# COMPANION_GRID_ROWS=3
# COMPANION_GRID_COLS=15
# COMPANION_MQTT_BROKER=192.168.1.50
# COMPANION_MQTT_PORT=1883
# COMPANION_MQTT_PREFIX=splitflap
# COMPANION_MQTT_USER=

# Where app settings, playlists, triggers + uploaded apps live (a volume in Docker)
# COMPANION_DATA_DIR=/data

# Where the companion's settings are stored (needs Gateway 3.1+ for the gateway):
#   mirror  = local file is primary, mirrored to the gateway (gzipped) on change; a
#             fresh companion host with no local file restores from the gateway (default)
#   local   = local file only, never touch the gateway (this is the pre-3.1 behavior)
#   gateway = stored ONLY on the gateway, nothing written locally (diskless companion)
# On a pre-3.1 gateway this automatically degrades to local (fully 3.0-compatible).
# COMPANION_SETTINGS_STORE=mirror

# Developer mode: enables SIMULATION MODE in the UI's ⚙ tools menu — apps run without
# sending to the display, with a grid rows/cols override while simulating. The menu
# itself (Vestaboard/MCP switches, resync, settings sync) is always available.
# COMPANION_DEV_MODE=1

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL (default INFO). DEBUG adds
# the companion's own detail (gateway sync, settings mirror, app fetches) without the
# noisy third-party wire logs.
# COMPANION_LOG_LEVEL=INFO
